# OneProduct Agent OS — Environment Configuration
# Copy this file to .env.local or .env.prod and fill in actual values

# ============================================
# Gemini API Configuration (Backend)
# ============================================
GEMINI_API_KEY= 
GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# Gemini API Configuration (Frontend)
# ============================================
# NOTE: Frontend values are bundled into the app—use backend proxy for production
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# Frontend Settings
# ============================================
VITE_API_BASE_URL=http://localhost:8000

# ============================================
# Docker / Registry Settings (CI/CD)
# ============================================
REGISTRY=ghcr.io/yourorg/oneproduct
IMAGE_TAG=latest

# ============================================
# Database (optional, for future use)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost/oneproduct
# DATABASE_POOL_SIZE=10

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info

# ============================================
# Kubernetes Settings (if using k8s)
# ============================================
NAMESPACE=oneproduct
DOMAIN=oneproduct.local

# ============================================
# Security
# ============================================
# CORS_ORIGINS=http://localhost:5173,https://oneproduct.example.com
# ALLOWED_HOSTS=localhost,oneproduct.example.com
