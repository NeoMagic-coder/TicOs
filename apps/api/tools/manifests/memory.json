{
  "tool_id": "memory_search",
  "name": "Memory Search",
  "description": "Vektör belleğinden cosine similarity ile en yakın dokümanları getirir (kullanıcı mesajları, geçmiş agent çıktıları, manuel notlar).",
  "category": "memory",
  "provider": "internal",
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {"type": "string", "description": "Arama metni."},
      "k": {"type": "integer", "minimum": 1, "maximum": 25, "default": 5},
      "kind": {
        "type": "string",
        "enum": ["user_message", "agent_output", "tool_result", "doc"],
        "description": "Sadece bu türdeki dokümanları döndür."
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "matches": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {"type": "string"},
            "kind": {"type": "string"},
            "agent_id": {"type": ["string", "null"]},
            "task_id": {"type": ["string", "null"]},
            "text": {"type": "string"},
            "score": {"type": "number"}
          }
        }
      }
    }
  },
  "allowed_agents": [],
  "cost_estimate_usd": 0.0001,
  "mode": "live",
  "tags": ["memory", "rag"]
}
