@page "/agents"
@rendermode InteractiveServer
@inject AgentApiClient Api

<h1 class="page-title">🤖 Ajan Rosteri</h1>

@if (_agents is null)
{
    <p class="muted">Yükleniyor…</p>
}
else
{
    <table class="agents-table fade-in">
        <thead>
            <tr>
                <th></th>
                <th>Ajan</th>
                <th>Rol</th>
                <th>Hedef</th>
                <th>Araç</th>
                <th>Güven</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in _agents)
            {
                <tr style="--accent: @(a.Color ?? "#6366f1")">
                    <td class="icon-cell">@(a.Icon ?? "🤖")</td>
                    <td><strong>@a.Name</strong></td>
                    <td>@a.Role</td>
                    <td class="muted">@a.Goal</td>
                    <td>@(a.AllowedTools?.Count ?? 0)</td>
                    <td>
                        @if (a.Stats is not null)
                        {
                            <div class="confidence-wrap">
                                <div class="confidence-fill"
                                     style="width: @((a.Stats.AvgConfidence * 100).ToString("0"))%"></div>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AgentSpec>? _agents;

    protected override async Task OnInitializedAsync()
    {
        _agents = (await Api.GetAgentsAsync()).ToList();
    }
}
