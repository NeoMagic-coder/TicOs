# Copy to a secure deployment secret store; do not commit real values.
POSTGRES_PASSWORD=replace-with-a-long-random-password
API_KEY=replace-with-a-long-random-api-key
PUBLIC_HOST=app.example.com
FRONTEND_URL=https://ticosclaw.web.app
VITE_API_BASE_URL=https://api.example.com

# Reverse proxy binds locally by default. Terminate TLS in front of this port.
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Optional Gemini-native image, vision, voice and embedding support.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firebase Auth (recommended for Firebase Hosting static deploy)
FIREBASE_PROJECT_ID=ticosclaw

# Google OAuth / OIDC login. Create a Web application client in Google Cloud
# Console and register:
#   https://app.example.com/api/v1/auth/callback
AUTH_ENABLED=true
AUTH_SESSION_SECRET=replace-with-python-secrets-token-urlsafe-48
AUTH_COOKIE_SECURE=true
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://app.example.com/api/v1/auth/callback
OAUTH_ALLOWED_EMAIL_DOMAINS=[]

DAILY_BUDGET_MAX_USD=10
