# Cloud Run ortam degiskenleri (gcloud run deploy --env-vars-file)
# Kopyala: docker/cloudrun.env.yaml ve gercek degerleri doldur.
ENVIRONMENT: production
DEBUG: "false"
DOCS_ENABLED: "false"
DEMO_ROUTES_ENABLED: "false"
HEALTH_DETAILS_ENABLED: "false"
SCHEDULER_ENABLED: "false"
DATABASE_URL: sqlite:////tmp/ticosclaw.db
AUTH_ENABLED: "false"
FIREBASE_PROJECT_ID: ticosclaw
FRONTEND_URL: https://ticosclaw.web.app
AUTH_COOKIE_SECURE: "true"
AUTH_SESSION_SECRET: replace-with-at-least-32-characters-secret
