# Production environment file
# Copy from .env.example and set actual secrets

# ============================================
# REQUIRED: Gemini API Keys
# ============================================
GEMINI_API_KEY=your-production-gemini-key-here
VITE_GEMINI_API_KEY=your-production-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
VITE_GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# API Configuration
# ============================================
VITE_API_BASE_URL=https://api.oneproduct.example.com

# ============================================
# Registry Settings
# ============================================
REGISTRY=ghcr.io/yourorg/oneproduct
IMAGE_TAG=v1.0.0

# ============================================
# Kubernetes Settings
# ============================================
NAMESPACE=oneproduct
DOMAIN=oneproduct.example.com

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
