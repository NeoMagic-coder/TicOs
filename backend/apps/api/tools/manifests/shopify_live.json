[
  {
    "tool_id": "shopify_store_setup",
    "name": "Shopify Mağaza Kurulum (Live)",
    "description": "Shopify Admin API'ya bağlanır, /shop.json üzerinden mağaza bilgisini doğrular ve kurulum checklist'i üretir. Credentials yoksa veya breaker OPEN'sa mock'a düşer.",
    "category": "store",
    "provider": "shopify",
    "auth_required": true,
    "timeout_ms": 15000,
    "input_schema": {
      "type": "object",
      "properties": {
        "shop_name": {"type": "string"},
        "country": {"type": "string", "default": "TR"}
      },
      "required": []
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "shop": {"type": "object"},
        "checklist": {"type": "array"},
        "estimated_setup_hours": {"type": "number"},
        "degraded": {"type": "boolean"}
      }
    },
    "allowed_agents": ["store_setup_agent", "supervisor"],
    "cost_estimate_usd": 0.0,
    "mode": "live",
    "tags": ["store", "shopify", "live"]
  },
  {
    "tool_id": "shopify_get_orders",
    "name": "Shopify Siparişleri Listele",
    "description": "Son siparişleri getirir (status, financial_status, created_at_min ile filtrelenebilir).",
    "category": "order",
    "provider": "shopify",
    "auth_required": true,
    "timeout_ms": 15000,
    "input_schema": {
      "type": "object",
      "properties": {
        "limit": {"type": "integer", "minimum": 1, "maximum": 250, "default": 25},
        "status": {"type": "string", "enum": ["open", "closed", "cancelled", "any"], "default": "any"},
        "financial_status": {"type": "string", "enum": ["paid", "pending", "refunded", "voided"]},
        "created_at_min": {"type": "string", "description": "ISO 8601 timestamp"}
      },
      "required": []
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "count": {"type": "integer"},
        "orders": {"type": "array"},
        "degraded": {"type": "boolean"}
      }
    },
    "allowed_agents": ["operations_agent", "analytics_agent", "supervisor"],
    "cost_estimate_usd": 0.0,
    "mode": "live",
    "tags": ["order", "shopify", "live"]
  },
  {
    "tool_id": "shopify_update_inventory",
    "name": "Shopify Stok Güncelle",
    "description": "Bir SKU için belirli location'daki available stoğu set eder (POST /inventory_levels/set.json).",
    "category": "stock",
    "provider": "shopify",
    "auth_required": true,
    "timeout_ms": 15000,
    "requires_approval": true,
    "input_schema": {
      "type": "object",
      "properties": {
        "location_id": {"type": "integer"},
        "inventory_item_id": {"type": "integer"},
        "available": {"type": "integer", "minimum": 0}
      },
      "required": ["location_id", "inventory_item_id", "available"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "inventory_item_id": {"type": "integer"},
        "location_id": {"type": "integer"},
        "available": {"type": "integer"},
        "updated_at": {"type": "string"},
        "degraded": {"type": "boolean"}
      }
    },
    "allowed_agents": ["operations_agent", "supervisor"],
    "cost_estimate_usd": 0.0,
    "mode": "live",
    "tags": ["stock", "shopify", "live", "mutating"]
  }
]
