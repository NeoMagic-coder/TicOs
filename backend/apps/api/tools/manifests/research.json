    "tool_id": "web_search_grounded",
    "name": "Google Search Grounded Answer",
    "description": "Soruyu Gemini + Google Search ile yanıtlar; kaynak URI'leri döndürür.",
    "category": "research",
    "provider": "gemini",
    "auth_required": true,
    "timeout_ms": 30000,
    "input_schema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 128,
          "maximum": 4096,
          "default": 800
        }
      },
      "required": [
        "query"
      ]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "answer": {
          "type": "string"
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uri": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          }
        },
        "degraded": {
          "type": "boolean"
        }
      }
    },
    "allowed_agents": [
      "market_research_agent",
      "supervisor",
      "analytics_agent"
    ],
    "cost_estimate_usd": 0.003,
    "mode": "live",
    "tags": [
