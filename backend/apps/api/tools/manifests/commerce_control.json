        "overall_status": {"type": "string"},
        "modules": {"type": "array"}
      }
    },
    "allowed_agents": ["fraud_agent", "operations_agent", "support_agent", "supervisor", "autonomous_decision_agent"],
    "cost_estimate_usd": 0.002,
    "mode": "live",
