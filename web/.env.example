# =============================================================================
# Ticosclaw — Ortam Değişkenleri
# Kurulum: cp .env.example .env.local  (veya: npm run setup)
# Rehber:  KURULUM.md
# =============================================================================

# -----------------------------------------------------------------------------
# 🚀 DEPLOY — VPS (Docker + Caddy HTTPS). Sadece sunucuda gerekli.
# APP_DOMAIN: uygulamanın çalışacağı alan adı (DNS A kaydı VPS IP'sine bakmalı)
# ACME_EMAIL: Let's Encrypt sertifika bildirimleri için e-posta
# -----------------------------------------------------------------------------
APP_DOMAIN=
ACME_EMAIL=

# -----------------------------------------------------------------------------
# 🔴 ZORUNLU — Clerk (kimlik doğrulama)
# Key'ler olmadan uygulama demo modunda çalışır.
# Al: https://dashboard.clerk.com  veya  clerk auth login && clerk env pull
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# URL ayarları (değiştirmen gerekmez):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/tr/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/tr/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/tr/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/tr/onboarding

# -----------------------------------------------------------------------------
# 🔴 ZORUNLU — Supabase (veritabanı)
# Al: https://supabase.com/dashboard → Project Settings → API
# Migration: supabase/migrations/001_initial_schema.sql dosyasını SQL Editor'da çalıştır
# ⚠️ SUPABASE_SERVICE_ROLE_KEY gizli — NEXT_PUBLIC_ öneki KULLANMA, sadece sunucu tarafı
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# 🟡 ÖNERİLEN — OpenAI (chat, marka analizi, görsel üretimi)
# Al: https://platform.openai.com/api-keys
# ⚠️ Gizli anahtar — NEXT_PUBLIC_ öneki KULLANMA
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# ⚪ OPSİYONEL — Firecrawl (marka sitesi taraması)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# ⚪ OPSİYONEL — Sosyal medya OAuth (yoksa "demo" fallback kullanılır)
# -----------------------------------------------------------------------------
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
LINKEDIN_CLIENT_ID=
GMAIL_CLIENT_ID=
OUTLOOK_CLIENT_ID=
WORDPRESS_CLIENT_ID=
REDDIT_CLIENT_ID=
